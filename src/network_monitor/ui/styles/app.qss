/* ----- MONITOR VIEW -------- */

QWidget#monitor_view {
  background: palette(window);
}

QLabel {
  padding: 2px 0px;
  color: palette(text);
}

QWidget#stats_container {
  padding-top: 0px;
  padding-bottom: 0px;
}

/* ------ STATUS ------ */

QLabel#status_label {
  qproperty-alignment: 'AlignVCenter | AlignCenter';
  min-height: 40px;
  max-height: 40px;
  border-radius: 20px;
  min-width: 20px;
  padding: 0px 18px;
  font-weight: 700;
  font-size: 25px;
}

QLabel#status_label[status="online"] {
  background-color: #228B22; /* Forest Green */
  color: white;
}

QLabel#status_label[status="offline"] {
  background-color: #C41E3A; /* Cardinal Red */
  color: white;
}

QLabel#status_label[status="unreachable"] {
  background: #DAA520; /* Goldenrod */
  color: white;
}

QLabel#status_label[status="unknown"] {
  background-color: palette(mid);
  color: palette(button-text);
}

/* --------- METRICS --------- */

QLabel#metric_key {
  color: palette(text);
}

QLabel#metric_value {
  font-weight: 700;
  font-size: 17px;
  color: white;
}

QLabel#metric_value[metric="server"] {
    min-width: 140px;
    max-width: 220px;
}

/* Base pill styling */
QLabel#metric_value[kind="pill"] {
  qproperty-alignment: 'AlignVCenter | AlignCenter';
  max-height: 24px;
  min-height: 24px;
  min-width: 10px;
  padding: 0px 12px;
  border-radius: 12px;
  background: #228B22; /* Forest Green */
}

/* When status is DOWN, change pills to red */
QWidget#monitor_view[status="offline"] QLabel#metric_value[kind="pill"] {
  background: #C41E3A; /* Cardinal Red */
}

/* When status is UNREACHABLE, change pills to yellow */
QWidget#monitor_view[status="unreachable"] QLabel#metric_value[kind="pill"] {
  background: #DAA520; /* Goldenrod */
}

/* Keep server pill blue */
QWidget#monitor_view[status="online"] QLabel#metric_value[kind="pill"][metric="server"],
QWidget#monitor_view[status="offline"] QLabel#metric_value[kind="pill"][metric="server"],
QWidget#monitor_view[status="unreachable"] QLabel#metric_value[kind="pill"][metric="server"] {
  background: #0F52BA; /* Sapphire Blue */
}

/* Latency severity */
QLabel#metric_value[kind="pill"][metric="latency"][level="warn"] {
  background: #DAA520; /* Goldenrod */
}

QLabel#metric_value[kind="pill"][metric="latency"][level="bad"] {
  background: #C41E3A; /* Cardinal Red */
}

/* Disconnect severity */
QLabel#metric_value[kind="pill"][metric="disconnects"][level="warn"] {
  background: #DAA520; /* Goldenrod */
}

QLabel#metric_value[kind="pill"][metric="disconnects"][level="bad"] {
  background: #C41E3A; /* Cardinal Red */
}


/* ------SEPARATOR & BOTTOM BAR ------- */

QFrame#separator_top,
QFrame#separator_middle,
QFrame#separator_bottom {
  border: none;
  min-height: 2px;
  max-height: 2px;
  background: palette(light);
}

QFrame#settings_bar {
  background: palette(base);
  padding-top: 2px;
  padding-bottom: 6px;
  border: none;
}

/* ---------- BUTTONS ---------- */

QPushButton#settings_button {
  min-width: 100px;
  min-height: 30px;
  max-height: 30px;
  border-radius: 15px;
  padding: 0px 10px;
  font-weight: 300;
  font-size: 14px;

  border: 2px solid palette(mid);
  background: palette(button);
  color: palette(button-text);
}

QPushButton#settings_button:hover {
  background: palette(midlight);
}

QPushButton#settings_button:pressed {
  background: palette(light);
}
